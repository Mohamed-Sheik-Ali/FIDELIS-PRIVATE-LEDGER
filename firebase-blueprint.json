{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "name": {
          "type": "string",
          "description": "Display name of the user"
        },
        "createdAt": {
          "type": "string",
          "description": "The timestamp when the user profile was created"
        }
      },
      "required": ["email", "name", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Category schema for grouping transactions",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the category"
        },
        "name": {
          "type": "string",
          "description": "Categorization visible name"
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense"],
          "description": "Asset flow direction classification"
        },
        "icon": {
          "type": "string",
          "description": "Lucide icon string key representation"
        },
        "color": {
          "type": "string",
          "description": "Tailwind visual theme representation class"
        },
        "userId": {
          "type": "string",
          "description": "Reference lookup identifier of owner"
        },
        "createdAt": {
          "type": "string",
          "description": "The timestamp of category creation"
        }
      },
      "required": ["id", "name", "type", "icon", "color", "userId", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An individual ledger debit or credit entry",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique ledger item listing tracker"
        },
        "amount": {
          "type": "number",
          "description": "The absolute currency value of financial flow"
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense"],
          "description": "Category flow direction representation"
        },
        "categoryId": {
          "type": "string",
          "description": "Categorical mapping identifier representation link"
        },
        "note": {
          "type": "string",
          "description": "Explanatory memo attached to record"
        },
        "date": {
          "type": "string",
          "description": "Calendar format calendar date recorded YYYY-MM-DD"
        },
        "userId": {
          "type": "string",
          "description": "Lookup identification tracker of transaction owner"
        },
        "createdAt": {
          "type": "string",
          "description": "Server tracking sequence identifier"
        }
      },
      "required": ["id", "amount", "type", "categoryId", "note", "date", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Primary user profile storage"
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "Personalized catalog schemas for grouping logs"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Ledger registers recorded in isolation"
    }
  }
}
